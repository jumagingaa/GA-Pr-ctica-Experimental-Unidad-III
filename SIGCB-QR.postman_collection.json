{
  "info": {
    "name": "SIGCB-QR API",
    "description": "API del Sistema Integral de Gestión, Control y Seguimiento de Lectura Interna en la Biblioteca Universitaria mediante Códigos QR e Inteligencia Artificial.\n\nAutenticación mediante JWT en cookie HttpOnly (access_token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "sigcbqr"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@dev.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Inicia sesión y recibe un JWT en cookie HttpOnly (access_token)."
          },
          "response": []
        },
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Nuevo Usuario\",\n  \"email\": \"nuevo@correo.com\",\n  \"password\": \"123456\",\n  \"telefono\": \"809-000-0000\",\n  \"rolId\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registra un nuevo usuario y devuelve JWT en cookie HttpOnly."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Cierra la sesión actual. Invalida el JTI del token en la blacklist y limpia la cookie."
          },
          "response": []
        },
        {
          "name": "Usuario actual (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Obtiene los datos del usuario autenticado mediante el JWT en cookie."
          },
          "response": []
        }
      ]
    },
